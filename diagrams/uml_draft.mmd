classDiagram
    class Pet {
        -string petName
        -string petBreed
        -string ownerName
        -Task[] taskList
        +add_task(task)
        +remove_task(task_id)
        +get_tasks()
    }

    class Task {
        -string taskName
        -int priority
        -boolean completed
        -int duration
        +mark_completed()
        +update_priority(priority)
        +update_duration(duration)
    }

    class Planner {
        -string constraints
        -string explanation
        -string dailyPlan
        +generate_daily_plan(pet)
        +explain_plan()
    }

    class PawPal {
        -Pet[] pets
        -Planner planner
        +add_pet(pet)
        +remove_pet(pet_id)
        +get_pet(pet_id)
        +run_planner(pet)
    }

    Pet "1" o-- "*" Task : contains
    PawPal "1" o-- "*" Pet : manages
    PawPal "1" o-- "1" Planner : uses
    Planner --> Pet : plans for
