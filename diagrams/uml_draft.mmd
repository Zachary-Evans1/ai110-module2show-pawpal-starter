classDiagram
    class Task {
        -int id
        -string name
        -string description
        -string frequency
        -string|null time_of_day
        -boolean completed
        -int priority
        -int duration
        +mark_completed()
        +update_priority(priority)
        +update_duration(duration)
    }

    class Pet {
        -int id
        -string name
        -string breed
        -string owner_name
        -Task[] tasks
        +add_task(task)
        +remove_task(task_id)
        +get_tasks()
    }

    class Constraint {
        -string constraint_type
        -string value
    }

    class Scheduler {
        -Pet|null current_pet
        -string|null plan_date
        -Constraint[] constraint_list
        -string explanation
        -string daily_plan
        +generate_daily_plan(pet)
        +explain_plan()
    }

    class Owner {
        -Pet[] pets
        -Scheduler|null scheduler
        +add_pet(pet)
        +remove_pet(pet_id)
        +get_pet(pet_id)
        +run_scheduler(pet)
    }

    Pet "1" o-- "*" Task : contains
    Scheduler "1" o-- "*" Constraint : uses
    Scheduler "1" --> "1" Pet : plans for
    Owner "1" o-- "*" Pet : manages
    Owner "1" o-- "1" Scheduler : uses